# Server Configuration
PORT=5000
NODE_ENV=development

# Database (MongoDB Atlas recommended for Render)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/crypto-platform?retryWrites=true&w=majority

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Admin Credentials (First Time Setup)
ADMIN_EMAIL=admin@cryptoplatform.com
ADMIN_PASSWORD=Admin@123456

# Email Configuration (Optional - for email verification)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Client URL (your Render app URL in production)
CLIENT_URL=https://your-app-name.onrender.com

# Crypto API (Optional - for real crypto prices)
CRYPTO_API_KEY=your_crypto_api_key
